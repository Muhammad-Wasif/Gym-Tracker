<Window x:Class="FitTrack.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FitTrack.UI.ViewModels"
        Title="Login" Height="600" Width="900" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" ClipToBounds="True" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Half (Decorative) -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}">
                <Grid>
                    <Canvas x:Name="BgCanvas" ClipToBounds="True" Opacity="0.8">
                        <Ellipse x:Name="Circle1" Width="400" Height="400" Fill="{StaticResource BrandBrush}" Opacity="0.05" Canvas.Left="-100" Canvas.Top="-100">
                            <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="Circle2" Width="300" Height="300" Fill="{StaticResource CyanBrush}" Opacity="0.04" Canvas.Left="200" Canvas.Top="300">
                            <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="Circle3" Width="500" Height="500" Fill="{StaticResource PurpleBrush}" Opacity="0.03" Canvas.Left="-50" Canvas.Top="200">
                            <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="FIT-TRACK" FontSize="72" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource BrandBrush}" Margin="0,0,0,-10"/>
                        <TextBlock Text="PRO" FontSize="72" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource BrandBrush}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#2563EB" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Track. Train. Transform." FontSize="14" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="4,8,0,0">
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Half (Form) -->
            <Border Grid.Column="1" Background="{StaticResource AppBgBrush}">
                <Grid x:Name="FormContainer">
                    <Grid.RenderTransform>
                        <TranslateTransform X="40"/>
                    </Grid.RenderTransform>
                    <!-- Close button -->
                    <Button Content="✕" Width="40" Height="40" Background="Transparent" Foreground="{StaticResource TextSecBrush}" 
                            BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" 
                            FontSize="16" Click="CloseButton_Click" Cursor="Hand"/>
                    
                    <StackPanel MaxWidth="320" VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                        <TextBlock Text="Welcome back" FontSize="24" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sign in to continue" FontSize="13" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,32"/>
                        
                        <TextBlock Text="Username" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource TextInput}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 x:Name="UsernameBox" Tag="Enter your username" Margin="0,0,0,16"/>
                                 
                        <TextBlock Text="Password" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                        <PasswordBox Style="{StaticResource PasswordInput}" x:Name="PasswordBox" Tag="Enter your password" 
                                     PasswordChanged="PasswordBox_PasswordChanged" Margin="0,0,0,24"/>
                        
                        <Button Style="{StaticResource PrimaryButton}" Content="Sign In" Command="{Binding LoginCommand}"/>
                        
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource RedBrush}" FontSize="12" 
                                   HorizontalAlignment="Center" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                   
                        <Button Style="{StaticResource GhostButton}" Content="Create an account" Command="{Binding NavigateToRegisterCommand}" Margin="0,16,0,0" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
