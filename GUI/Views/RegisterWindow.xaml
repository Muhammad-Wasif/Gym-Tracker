<Window x:Class="FitTrack.UI.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FitTrack.UI.ViewModels"
        Title="Register" Height="700" Width="900" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:RegisterViewModel/>
    </Window.DataContext>
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" ClipToBounds="True" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Half (Decorative) -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}">
                <Grid>
                    <Canvas x:Name="BgCanvas" ClipToBounds="True" Opacity="0.8">
                        <Ellipse x:Name="Circle1" Width="300" Height="300" Fill="{StaticResource GreenBrush}" Opacity="0.05" Canvas.Left="-50" Canvas.Top="-50">
                            <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="JOIN" FontSize="48" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                        <TextBlock Text="FIT-TRACK" FontSize="48" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource BrandBrush}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#2563EB" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Start your journey." FontSize="14" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="4,8,0,0">
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Half (Form) -->
            <Border Grid.Column="1" Background="{StaticResource AppBgBrush}">
                <Grid x:Name="FormContainer">
                    <Grid.RenderTransform>
                        <TranslateTransform X="40"/>
                    </Grid.RenderTransform>
                    <!-- Close button -->
                    <Button Content="✕" Width="40" Height="40" Background="Transparent" Foreground="{StaticResource TextSecBrush}" 
                            BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" 
                            FontSize="16" Click="CloseButton_Click" Cursor="Hand"/>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="400">
                            <TextBlock Text="Create Account" FontSize="24" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Please fill in the details" FontSize="13" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,24"/>
                            
                            <StackPanel>
                                <TextBlock Text="Full Name" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource TextInput}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Tag="Enter your full name" Margin="0,0,0,14"/>
                                
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Username" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource TextInput}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Tag="Username"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Email" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource TextInput}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Tag="Email address"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Password" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                <PasswordBox Style="{StaticResource PasswordInput}" x:Name="PasswordBox" Tag="Create a password" PasswordChanged="PasswordBox_PasswordChanged" Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Age" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource TextInput}" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Tag="Age"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Gender" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <ComboBox SelectedValue="{Binding Gender}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Male"/><ComboBoxItem Content="Female"/><ComboBoxItem Content="Other"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Height (cm)" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource TextInput}" Text="{Binding HeightCm, UpdateSourceTrigger=PropertyChanged}" Tag="Height"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Weight (kg)" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                        <TextBox Style="{StaticResource TextInput}" Text="{Binding WeightKg, UpdateSourceTrigger=PropertyChanged}" Tag="Weight"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Fitness Goal" FontSize="12" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Goals}" SelectedItem="{Binding SelectedGoal}" DisplayMemberPath="GoalName" Margin="0,0,0,24"/>
                            </StackPanel>
                            
                            <Button Style="{StaticResource PrimaryButton}" Content="Register" Command="{Binding RegisterCommand}"/>
                            
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource RedBrush}" FontSize="12" 
                                       HorizontalAlignment="Center" Margin="0,16,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                                       
                            <Button Style="{StaticResource GhostButton}" Content="Back to Login" Command="{Binding NavigateToLoginCommand}" Margin="0,16,0,0" BorderThickness="0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
