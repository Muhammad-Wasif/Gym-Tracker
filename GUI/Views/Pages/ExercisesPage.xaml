<Page x:Class="FitTrack.UI.Views.Pages.ExercisesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FitTrack.UI.ViewModels"
      Title="Exercises">
    <Page.DataContext>
        <vm:ExercisesViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Exercise Library" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Search exercises by name or muscle group..." Margin="0,0,0,24"/>
                             
                    <ItemsControl ItemsSource="{Binding FilteredExercises}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DataCard}" Margin="0,0,0,12" Padding="16" Cursor="Hand"
                                        MouseLeftButtonUp="ExerciseCard_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitle}" Grid.Column="0" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="{StaticResource CardHoverBrush}" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="{Binding MuscleGroup}" Style="{StaticResource Caption}" Foreground="{StaticResource BrandBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Border Style="{StaticResource DataCard}" Grid.Column="1" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- When No Selection -->
                        <TextBlock Text="Select an exercise to view details." Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecBrush}"
                                   Visibility="{Binding SelectedExercise, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        
                        <!-- When Selected -->
                        <StackPanel Visibility="{Binding SelectedExercise, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedExercise.Name}" FontSize="20" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Muscle Group:" Style="{StaticResource Caption}" Foreground="{StaticResource TextSecBrush}" Grid.Column="0" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SelectedExercise.MuscleGroup}" Style="{StaticResource BodyText}" Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Equipment:" Style="{StaticResource Caption}" Foreground="{StaticResource TextSecBrush}" Grid.Column="0" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SelectedExercise.Equipment}" Style="{StaticResource BodyText}" Grid.Column="1"/>
                            </Grid>
                            
                            <TextBlock Text="Description" Style="{StaticResource Caption}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SelectedExercise.Description}" Style="{StaticResource BodyText}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
