<Page x:Class="FitTrack.UI.Views.Pages.TrainerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FitTrack.UI.ViewModels"
      Title="Trainer Portal">
    <Page.DataContext>
        <vm:TrainerViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Trainer Portal" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource DataCard}" Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="My Trainees" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding AssignedTrainees}" SelectedItem="{Binding SelectedTrainee}" 
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  Background="Transparent" BorderThickness="0" RowBackground="Transparent" 
                                  AlternatingRowBackground="{StaticResource AppBgBrush}" GridLinesVisibility="None"
                                  HeadersVisibility="Column" Foreground="{StaticResource TextPrimaryBrush}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
                                    <Setter Property="FontFamily" Value="{StaticResource DMSans}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DataCard}" Grid.Column="1" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Trainee Details" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Select a trainee from the list." Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecBrush}"
                                   Visibility="{Binding SelectedTrainee, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                   
                        <StackPanel Visibility="{Binding SelectedTrainee, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding TraineeDetailsText}" Style="{StaticResource BodyText}" Margin="0,0,0,24" TextWrapping="Wrap"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Assign Workout Plan" Command="{Binding AssignPlanCommand}" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource RedBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
