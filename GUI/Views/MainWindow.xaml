<Window x:Class="FitTrack.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="FitTrack Pro" Height="768" Width="1280"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <!-- Title Bar -->
            <Grid Height="36" Background="Transparent" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_Drag" Panel.ZIndex="10">
                <TextBlock Text="FIT-TRACK PRO" VerticalAlignment="Center" Margin="16,0"
                           FontFamily="{StaticResource DMSans}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0">
                    <Button Content="—" Width="30" Height="24" Background="Transparent" Foreground="{StaticResource TextSecBrush}" BorderThickness="0" Click="Minimize_Click"/>
                    <Button Content="✕" Width="30" Height="24" Background="Transparent" Foreground="{StaticResource TextSecBrush}" BorderThickness="0" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Content Grid -->
            <Grid Margin="0,36,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Panel -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" Margin="16,24,16,16">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource BrandBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="FIT-TRACK PRO" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource DMSans}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                        </StackPanel>

                        <!-- Nav Items -->
                        <StackPanel Grid.Row="1" Margin="0,16,0,0" x:Name="NavItemsPanel">
                            <Button Style="{StaticResource NavItemStyle}" Tag="Dashboard" Click="NavItem_Click" IsDefault="True">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Home" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Dashboard" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemStyle}" Tag="Workouts" Click="NavItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Tasks" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Workouts" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemStyle}" Tag="Exercises" Click="NavItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Heartbeat" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Exercises" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemStyle}" Tag="Nutrition" Click="NavItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Cutlery" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Nutrition" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemStyle}" Tag="Progress" Click="NavItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="LineChart" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Progress" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="16,8" x:Name="RoleSeparator"/>
                            
                            <Button Style="{StaticResource NavItemStyle}" Tag="Trainer" Click="NavItem_Click" x:Name="TrainerNav">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Users" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Trainer" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemStyle}" Tag="Admin" Click="NavItem_Click" x:Name="AdminNav">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Cog" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Admin" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Bottom Section -->
                        <StackPanel Grid.Row="3" Margin="16,0,16,24">
                            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="ProfileCard_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="32" Height="32" Fill="{StaticResource BrandBrush}" Grid.Column="0"/>
                                    <TextBlock x:Name="UserInitials" Text="MW" Foreground="White" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource DMSans}" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0"/>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="UserFullName" Text="Full Name" Style="{StaticResource CardTitle}" FontSize="13"/>
                                        <TextBlock x:Name="UserRole" Text="Role" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Button Style="{StaticResource NavItemStyle}" Click="SignOut_Click" Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="SignOut" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Sign Out" Margin="12,0,0,0" FontFamily="{StaticResource DMSans}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content Frame -->
                <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Grid>
    </Border>
</Window>
