<Window x:Class="FitTrack.UI.Dialogs.LogWorkoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Workout Session" Height="550" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid x:Name="FormContainer" Margin="32">
            <Grid.RenderTransform>
                <TranslateTransform Y="20"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Log Workout Session" Style="{StaticResource SectionTitle}"/>
                <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextSecBrush}" 
                        BorderThickness="0" HorizontalAlignment="Right" Click="Close_Click" Cursor="Hand"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Duration (minutes)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource TextInput}" x:Name="DurationBox" Text="30" Margin="0,0,0,12"/>

                    <TextBlock Text="Notes (optional)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource TextInput}" x:Name="NotesBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,16"/>

                    <TextBlock Text="Exercises" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                    <TextBlock Text="Select exercise and log sets below:" Style="{StaticResource Caption}" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,8"/>
                    
                    <ComboBox x:Name="ExerciseCombo" DisplayMemberPath="Name" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource TextInput}" x:Name="RepsBox" Tag="Reps" Grid.Column="0"/>
                        <TextBox Style="{StaticResource TextInput}" x:Name="WeightBox" Tag="Weight (kg)" Grid.Column="2"/>
                        <Button Style="{StaticResource GhostButton}" Content="+ Add Set" Click="AddSet_Click" Grid.Column="4"/>
                    </Grid>

                    <ListBox x:Name="SetsList" Height="100" Background="Transparent" BorderThickness="0" 
                             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource RedBrush}" FontSize="12"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="Close_Click" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="Log Session" Click="LogSession_Click" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
