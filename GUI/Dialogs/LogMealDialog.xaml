<Window x:Class="FitTrack.UI.Dialogs.LogMealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Meal" Height="500" Width="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid x:Name="FormContainer" Margin="32">
            <Grid.RenderTransform>
                <TranslateTransform Y="20"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Log Meal" Style="{StaticResource SectionTitle}"/>
                <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextSecBrush}" 
                        BorderThickness="0" HorizontalAlignment="Right" Click="Close_Click" Cursor="Hand"/>
            </Grid>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Search Food" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource TextInput}" x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Margin="0,0,0,12"/>
                
                <ListBox x:Name="FoodList" Height="150" Background="Transparent" BorderThickness="0" 
                         Foreground="{StaticResource TextPrimaryBrush}" SelectionChanged="FoodList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FoodName}" Style="{StaticResource BodyText}" Margin="8,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Meal Type" Style="{StaticResource Caption}" Margin="0,12,0,6"/>
                <ComboBox x:Name="MealTypeCombo" SelectedIndex="0">
                    <ComboBoxItem Content="Breakfast"/>
                    <ComboBoxItem Content="Lunch"/>
                    <ComboBoxItem Content="Dinner"/>
                    <ComboBoxItem Content="Snack"/>
                </ComboBox>

                <TextBlock Text="Serving (grams)" Style="{StaticResource Caption}" Margin="0,12,0,6"/>
                <TextBox Style="{StaticResource TextInput}" x:Name="ServingBox" Text="100" Margin="0,0,0,12"/>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource RedBrush}" FontSize="12" Margin="0,0,0,8"/>
                <TextBlock x:Name="SuccessText" Foreground="{StaticResource GreenBrush}" FontSize="12"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="Close_Click" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="Log Meal" Click="LogMeal_Click" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
