<Window x:Class="FitTrack.UI.Dialogs.LogProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Progress" Height="400" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Border Background="{StaticResource AppBgBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid x:Name="FormContainer" Margin="32">
            <Grid.RenderTransform>
                <TranslateTransform Y="20"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Log Progress Snapshot" Style="{StaticResource SectionTitle}"/>
                <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextSecBrush}" 
                        BorderThickness="0" HorizontalAlignment="Right" Click="Close_Click" Cursor="Hand"/>
            </Grid>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Weight (kg)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource TextInput}" x:Name="WeightBox" Margin="0,0,0,12"/>

                <TextBlock Text="Body Fat % (optional)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource TextInput}" x:Name="BodyFatBox" Margin="0,0,0,12"/>

                <TextBlock Text="Notes (optional)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource TextInput}" x:Name="NotesBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource RedBrush}" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="Close_Click" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="Save Snapshot" Click="Save_Click" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
